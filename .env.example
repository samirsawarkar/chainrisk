# Google Gemini — get a key at https://aistudio.google.com/app/apikey
# Uses the OpenAI-compatible Gemini HTTP API (see https://ai.google.dev/gemini-api/docs/openai)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional (defaults match backend/app/config.py)
# GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# Use IDs that work on the OpenAI-compat endpoint (see Google docs; old IDs may 404).
# GEMINI_MODEL_DEFAULT=gemini-2.5-flash
# GEMINI_MODEL_JSON=gemini-2.5-flash
# GEMINI_MODEL_PROFILE=gemini-2.5-flash
# GEMINI_MODEL_REPORT=gemini-3-flash-preview
# GEMINI_MODEL_OASIS_PARALLEL_A=gemini-2.5-flash
# GEMINI_MODEL_OASIS_PARALLEL_B=gemini-3-flash-preview
# GEMINI_MODEL_OASIS_TWITTER=gemini-2.5-flash
# GEMINI_MODEL_OASIS_REDDIT=gemini-3-flash-preview

# ===== Zep knowledge graph =====
# Free tier is enough for light usage: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here
